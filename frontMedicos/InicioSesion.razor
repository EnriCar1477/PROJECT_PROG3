@page "/"

@layout EmptyLayout

<style>
    /* Fondo sutil para que las tarjetas blancas resalten */
    .login-bg {
        background-color: #f8f9fa;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* Efecto de la tarjeta similar a la imagen (borde redondeado, sombra suave) */
    .role-card {
        border-radius: 1rem;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border: 1px solid #eaeaea;
    }

        .role-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important;
        }

    /* Contenedor del ícono */
    .icon-container {
        height: 80px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1rem;
    }
</style>

<div class="login-bg py-5">
    <div class="container">

        <!-- ENCABEZADO LOGO/TÍTULO -->
        <div class="text-center mb-5">
            <h1 class="fw-bold" style="color: #0d6efd;">
                <i class="bi bi-hospital text-success me-2"></i>MediTrack
            </h1>
            <p class="text-muted fs-5">Seleccione su perfil para acceder al sistema</p>
        </div>

        <!-- CONTENEDOR DE LAS 3 TARJETAS CENTRADAS -->
        <div class="row justify-content-center g-4">

            <!-- TARJETA 1: SECRETARIO -->
            <div class="col-12 col-md-4">
                <div class="card role-card h-100 shadow-sm p-4">
                    <div class="card-body text-center d-flex flex-column">
                        <div class="icon-container">
                            <i class="bi bi-person-badge" style="font-size: 4rem; color: #17a2b8;"></i>
                        </div>
                        <h4 class="fw-bold text-dark mb-3">Secretaría</h4>
                        <p class="text-muted mb-4 flex-grow-1">
                            Gestiona el registro de pacientes, la agenda médica y la recepción de la clínica.
                        </p>
                        <!-- BOTÓN MEDIANO CENTRADO -->
                        <div class="d-grid">
                            <a href="citasSecretario" class="btn text-white fw-bold py-2 rounded-3" style="background-color: #17a2b8;">
                                Ingresar como: Secretario
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- TARJETA 2: MÉDICO -->
            <div class="col-12 col-md-4">
                <div class="card role-card h-100 shadow-sm p-4">
                    <div class="card-body text-center d-flex flex-column">
                        <div class="icon-container">
                            <!-- Ícono azul similar a la imagen -->
                            <i class="bi bi-heart-pulse-fill" style="font-size: 4rem; color: #4285F4;"></i>
                        </div>
                        <h4 class="fw-bold text-dark mb-3">Personal Médico</h4>
                        <p class="text-muted mb-4 flex-grow-1">
                            Revisa tus citas agendadas, pacientes, historias clínicas y turnos asignados.
                        </p>
                        <!-- BOTÓN MEDIANO CENTRADO -->
                        <div class="d-grid">
                            <a href="IngresarUsuarioMedico" class="btn text-white fw-bold py-2 rounded-3" style="background-color: #4285F4;">
                                Ingresar como: Medico
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- TARJETA 3: ADMINISTRADOR -->
            <div class="col-12 col-md-4">
                <div class="card role-card h-100 shadow-sm p-4">
                    <div class="card-body text-center d-flex flex-column">
                        <div class="icon-container">
                            <!-- Ícono verde similar a la imagen -->
                            <i class="bi bi-gear-wide-connected" style="font-size: 4rem; color: #34A853;"></i>
                        </div>
                        <h4 class="fw-bold text-dark mb-3">Administración</h4>
                        <p class="text-muted mb-4 flex-grow-1">
                            Administra usuarios, auditoría, parámetros y configuraciones del sistema.
                        </p>
                        <!-- BOTÓN MEDIANO CENTRADO -->
                        <div class="d-grid">
                            <a href="DashboardAdmin" class="btn text-white fw-bold py-2 rounded-3" style="background-color: #34A853;">
                                Ingresar como: administrador
                            </a>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

@code{

}
