@page "/ResumenDetalleHistorial"
<h3>ResumenDetalleHistorial</h3>

<div class="container-fluid py-4">

    <div class="d-flex align-items-center mb-4 justify-content-between">
        <div class="d-flex align-items-center">
            <a href="detalleHistorial" class="btn btn-outline-secondary me-3 rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                <i class="bi bi-arrow-left fs-5"></i>
            </a>
            <h2 class="fw-bold mb-0">Hoja Clínica - Resumen de Encuentro</h2>
        </div>
        <button class="btn btn-outline-dark btn-sm fw-bold px-3 py-2" onclick="window.print();">
            <i class="bi bi-printer me-2"></i>Imprimir Ficha
        </button>
    </div>

    <div class="card shadow-sm border-0 mb-4 bg-white">
        <div class="card-header fw-bold d-flex align-items-center py-3" style="background-color: #22C7D6; color: #000000;">
            <i class="bi bi-person-vcard fs-5 me-2"></i> I. Datos Personales del Paciente
        </div>
        <div class="card-body py-4">
            <div class="row g-4">
                <div class="col-md-4">
                    <label class="form-label text-muted small mb-1 fw-bold">Nombres y Apellidos</label>
                    <div class="fs-5 fw-bold text-dark">{ Ana Ramirez }</div>
                </div>
                <div class="col-md-2">
                    <label class="form-label text-muted small mb-1">Documento (DNI)</label>
                    <div class="text-dark fw-medium">{ 98765432 }</div>
                </div>
                <div class="col-md-2">
                    <label class="form-label text-muted small mb-1">Edad</label>
                    <div class="text-dark fw-medium">{ 28 años }</div>
                </div>
                <div class="col-md-2">
                    <label class="form-label text-muted small mb-1">Grupo Sanguíneo</label>
                    <div class="text-danger fw-bold">{ O+ } <i class="bi bi-droplet-fill"></i></div>
                </div>
                <div class="col-md-2">
                    <label class="form-label text-muted small mb-1 fw-bold">Alergias Registradas</label>
                    <div>
                        <span class="badge bg-danger bg-opacity-10 text-danger px-2 py-1 rounded fw-bold">
                            { Ninguna }
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4 bg-white">
        <div class="card-header fw-bold d-flex align-items-center py-3" style="background-color: #22C7D6; color: #000000;">
            <i class="bi bi-heart-pulse fs-5 me-2"></i> II. Examen Clínico Inicial (Triaje)
        </div>
        <div class="card-body">
            <div class="row text-center g-3">
                <div class="col-6 col-md-3">
                    <div class="p-3 bg-light rounded-3 border">
                        <small class="text-muted d-block mb-1">Presión Arterial</small>
                        <span class="fs-5 fw-bold text-dark">{ 120 / 80 mmHg }</span>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="p-3 bg-light rounded-3 border">
                        <small class="text-muted d-block mb-1">Temperatura</small>
                        <span class="fs-5 fw-bold text-dark">{ 37 °C }</span>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="p-3 bg-light rounded-3 border">
                        <small class="text-muted d-block mb-1">Frecuencia Cardíaca</small>
                        <span class="fs-5 fw-bold text-dark">{ 72 lpm }</span>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="p-3 bg-light rounded-3 border">
                        <small class="text-muted d-block mb-1">Peso / Talla</small>
                        <span class="fs-5 fw-bold text-dark">{ 62 kg / 1.65 m }</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4 bg-white">
        <div class="card-header fw-bold d-flex align-items-center py-3" style="background-color: #22C7D6; color: #000000;">
            <i class="bi bi-chat-left-text fs-5 me-2"></i> III. Anamnesis y Relato Clínico
        </div>
        <div class="card-body">
            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <span class="text-muted small fw-bold">Motivo Principal:</span>
                    <span class="text-dark ms-1">{ Dolor intenso de muela del juicio }</span>
                </div>
                <div class="col-md-4">
                    <span class="text-muted small fw-bold">Tiempo de Enfermedad:</span>
                    <span class="text-dark ms-1">{ 3 días }</span>
                </div>
                <div class="col-md-4">
                    <span class="text-muted small fw-bold">Forma de Inicio:</span>
                    <span class="text-dark ms-1">{ Súbito y progresivo }</span>
                </div>
            </div>
            <div class="bg-light p-3 rounded-3 border">
                <div class="text-muted small fw-bold text-uppercase mb-1">Relato Clínico Narrativo:</div>
                <p class="text-dark mb-0 style-justify" style="line-height: 1.5;">
                    { Paciente refiere dolor agudo localizado en la zona molar inferior derecha que se intensifica al masticar y al ingerir alimentos fríos. No refiere antecedentes de episodios similares. }
                </p>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">

        <div class="col-lg-6">
            <div class="card shadow-sm border-0 h-100 bg-white">
                <div class="card-header fw-bold d-flex align-items-center py-3" style="background-color: #22C7D6; color: #000000;">
                    <i class="bi bi-file-earmark-medical fs-5 me-2"></i> IV. Diagnósticos Registrados
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3" style="width: 120px;">Código CIE</th>
                                <th>Descripción Oficial de Enfermedad</th>
                                <th style="width: 110px;">Tipo</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="ps-3"><span class="badge bg-dark px-2 py-1">{ K08.14 }</span></td>
                                <td class="fw-medium text-dark">{ Retención radicular }</td>
                                <td><span class="badge bg-primary">{ Definitivo }</span></td>
                            </tr>
                        </tbody>
                    </table>
                    <div class="p-3 bg-light border-top">
                        <small class="text-muted fw-bold">Observaciones del diagnóstico:</small>
                        <div class="text-dark small mt-1">{ Pieza dental impactada con ligera inflamación gingival periférica. }</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card shadow-sm border-0 h-100 bg-white">
                <div class="card-header fw-bold d-flex align-items-center py-3" style="background-color: #22C7D6; color: #000000;">
                    <i class="bi bi-capsule-has fs-5 me-2"></i> V. Plan de Tratamiento e Indicaciones
                </div>
                <div class="card-body p-0">
                    <div class="p-3 border-bottom">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="badge bg-secondary px-3 py-1.5 fw-bold">{ FARMACOLOGICO }</span>
                            <small class="text-muted">Vigencia: <strong>{ 13/05/2026 al 20/05/2026 }</strong></small>
                        </div>
                        <div class="text-muted small fw-bold">Indicaciones Clínicas:</div>
                        <div class="text-dark bg-light p-2 rounded border mt-1" style="font-size: 0.95rem; white-space: pre-line;">
                            { - Amoxicilina 875mg: Tomar 1 tableta cada 8 horas por 7 días.
                            - Ibuprofeno 400mg: Tomar 1 tableta cada 6 horas en caso de dolor persistente. }
                        </div>
                    </div>
                    <div class="p-3 bg-light text-muted small">
                        <div><i class="bi bi-calendar3 me-1"></i> <strong>Fecha de Cierre:</strong> { 13/05/2026 17:15:30 }</div>
                        <div><i class="bi bi-person-check-fill me-1"></i> <strong>Médico Auditor:</strong> { Dr. Juan Gómez Pérez (CMP 12345) }</div>
                        <div class="text-success fw-bold mt-1"><i class="bi bi-shield-fill-check me-1"></i> Documento Firmado Digitalmente e Inmutable</div>
                    </div>
                </div>
            </div>
        </div>

    </div>

</div>




@code {

}
