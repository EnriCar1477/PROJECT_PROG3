@page "/Diagnostico"
<h3>Diagnostico</h3>

<!-- ESTILOS PARA EL STEPPER CENTRADO CON CONECTORES FLEXIBLES Y COLOR DINÁMICO -->
<style>
    .stepper-container {
        display: flex;
        justify-content: center;
        align-items: center;
        flex-wrap: nowrap;
        margin-bottom: 2rem;
        overflow-x: auto;
    }

    /* Estilo base de los botones del stepper */
    .step-btn {
        flex: 0 0 auto;
        min-width: 140px;
        font-weight: bold;
        border-radius: 0.5rem;
        border: 2px solid transparent;
        padding: 0.5rem 1rem;
        text-align: center;
        transition: all 0.2s ease;
        background-color: #D1D5DB;
        color: #4b5563;
        text-decoration: none;
        display: inline-block;
    }

        .step-btn.completed, .step-btn.active {
            background-color: #0d6efd !important;
            color: white !important;
            border-color: #0d6efd !important;
        }

        .step-btn.clickable {
            cursor: pointer;
            pointer-events: auto;
        }

        .step-btn:not(.clickable) {
            pointer-events: none;
        }

    /* Conector base (gris por defecto) */
    .step-connector {
        width: 60px;
        height: 4px;
        background-color: #dee2e6;
        margin: 0 0.5rem;
        flex-shrink: 0;
        transition: background-color 0.2s ease;
    }

        /* Conector completado (azul) */
        .step-connector.completed {
            background-color: #0d6efd;
        }

    /* Ajustes responsivos */
    @@media (max-width: 992px) {
        .step-btn {
            min-width: 110px;
            font-size: 0.85rem;
            padding: 0.4rem 0.75rem;
        }

        .step-connector {
            width: 40px;
            margin: 0 0.25rem;
        }
    }

    @@media (max-width: 768px) {
        .step-btn {
            min-width: 90px;
            font-size: 0.75rem;
            padding: 0.3rem 0.5rem;
        }

        .step-connector {
            width: 25px;
            margin: 0 0.15rem;
        }

        .stepper-container {
            justify-content: flex-start;
        }
    }
</style>

<div class="container-fluid py-4">

    <!-- PANEL SUPERIOR: DATOS DEL PACIENTE -->
    <div class="d-flex justify-content-between align-items-center text-white p-3 rounded-3 mb-4 shadow-sm" style="background-color: #0d6efd;">
        <div class="d-flex align-items-center">
            <div class="rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 45px; height: 45px; background-color: rgba(255,255,255,0.3);">
                <i class="bi bi-person text-white fs-4"></i>
            </div>
            <h5 class="mb-0 fw-medium">Ana Ramirez (DNI: 98765432)</h5>
        </div>
        <div>
            <i class="bi bi-card-list fs-2" style="cursor: pointer;"></i>
        </div>
    </div>

    <!-- NAVEGACIÓN DE PASOS (STEPPER CENTRADO CON CONECTORES COLOREADOS) -->
    <div class="stepper-container">
        <!-- Paso 1: Triaje (completado, azul, clickeable) -->
        <a href="AgregarNuevoDetalleHistorial" class="step-btn completed clickable">Triaje</a>
        <!-- Conector 1: completado -> azul -->
        <div class="step-connector completed"></div>

        <!-- Paso 2: Anamnesis (completado, azul, clickeable) -->
        <a href="Anamnesis" class="step-btn completed clickable">Anamnesis</a>
        <!-- Conector 2: completado (ya se pasó de Anamnesis a Diagnóstico) -> azul -->
        <div class="step-connector completed"></div>

        <!-- Paso 3: Diagnóstico (activo, azul, no clickeable) -->
        <span class="step-btn active">Diagnóstico</span>
        <!-- Conector 3: pendiente (gris) -->
        <div class="step-connector"></div>

        <!-- Paso 4: Tratamiento (inactivo, gris) -->
        <span class="step-btn">Tratamiento</span>
        <div class="step-connector"></div>

        <!-- Paso 5: Cierre y Firma (inactivo, gris) -->
        <span class="step-btn">Cierre y Firma</span>
    </div>

    <!-- CONTENEDOR DEL FORMULARIO DE DIAGNÓSTICO -->
    <div class="card border border-2 rounded-3 shadow-sm">
        <div class="card-body p-5">

            <form>
                <!-- SECCIÓN DE INGRESO DE DIAGNÓSTICO -->
                <div class="row mb-4 g-4 align-items-end">

                    <!-- Búsqueda CIE-10 (BARRA DESPLEGABLE) -->
                    <div class="col-md-7">
                        <label class="form-label fw-bold text-dark mb-2">Enfermedad o Condición (Catálogo CIE-10)</label>
                        <select class="form-select border-dark">
                            <option value="" selected disabled>Seleccione una enfermedad del catálogo CIE-10...</option>
                            <option value="K08.14">K08.14 - Retención radicular</option>
                            <option value="K04.0">K04.0 - Pulpitis reversible</option>
                            <option value="J00">J00 - Resfriado común</option>
                            <option value="E11">E11 - Diabetes mellitus tipo 2</option>
                            <option value="I10">I10 - Hipertensión esencial (primaria)</option>
                        </select>
                    </div>

                    <!-- Tipo de Diagnóstico -->
                    <div class="col-md-3">
                        <label class="form-label fw-bold text-dark mb-2">Tipo de Diagnóstico</label>
                        <select class="form-select border-dark">
                            <option value="" selected disabled>Seleccione...</option>
                            <option value="P">Presuntivo (P)</option>
                            <option value="D">Definitivo (D)</option>
                            <option value="R">Repetitivo (R)</option>
                        </select>
                    </div>

                    <!-- Botón Agregar a la lista -->
                    <div class="col-md-2 d-grid">
                        <button type="button" class="btn btn-outline-primary fw-bold border-2">
                            <i class="bi bi-plus-lg me-1"></i> Agregar
                        </button>
                    </div>
                </div>

                <!-- TABLA DE DIAGNÓSTICOS REGISTRADOS PARA ESTA CONSULTA -->
                <div class="mb-5">
                    <h6 class="fw-bold text-secondary mb-3"><i class="bi bi-list-check me-2"></i>Diagnósticos Registrados para esta Consulta</h6>
                    <div class="table-responsive border rounded">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-3" style="width: 120px;">Código CIE</th>
                                    <th>Descripción de la Enfermedad</th>
                                    <th style="width: 150px;">Tipo</th>
                                    <th class="text-center" style="width: 100px;">Acción</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Ejemplo de un diagnóstico ya agregado a la lista -->
                                <tr>
                                    <td class="ps-3"><span class="badge bg-dark px-2 py-1">K08.14</span></td>
                                    <td class="fw-medium text-dark">Retención radicular</td>
                                    <td><span class="badge bg-primary">Definitivo</span></td>
                                    <td class="text-center">
                                        <button type="button" class="btn btn-sm btn-outline-danger border-0">
                                            <i class="bi bi-trash3-fill"></i>
                                        </button>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="row mb-5">
                    <div class="col-12">
                        <label class="form-label fw-bold text-dark mb-2">Observaciones Clínicas (Opcional)</label>
                        <textarea class="form-control border-dark" rows="3" placeholder="Detalles adicionales sobre el diagnóstico de este paciente..."></textarea>
                    </div>
                </div>

                <!-- BOTONES DE ACCIÓN -->
                <div class="d-flex justify-content-center gap-4 mt-4 border-top pt-4">
                    <!-- Botón retroceder -->
                    <a href="Anamnesis" class="btn btn-outline-dark fw-bold rounded-2" style="width: 250px; padding-top: 10px; padding-bottom: 10px;">
                        RETROCEDER
                    </a>

                    <!-- Botón continuar a Tratamiento -->
                    <a href="Tratamiento" class="btn btn-primary fw-bold text-white rounded-2 d-flex align-items-center justify-content-center" style="width: 250px; padding-top: 10px; padding-bottom: 10px; background-color: #0d6efd; text-decoration: none;">
                        CONTINUAR
                    </a>
                </div>
            </form>

        </div>
    </div>
</div>