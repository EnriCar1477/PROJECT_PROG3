@page "/IngresarUsuarioMedico"
<h3>IngresarUsuarioMedico</h3>
@layout Layout.EmptyLayout

<style>
    /* Fondo que ocupa toda la pantalla */
    .login-bg {
        background-color: #f8f9fa;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* Estilo de la tarjeta de login centrada */
    .login-card {
        border-radius: 1rem;
        border: 1px solid #eaeaea;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        background-color: white;
    }

    /* Círculo para el ícono del médico */
    .avatar-circle {
        width: 80px;
        height: 80px;
        background-color: rgba(66, 133, 244, 0.1);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem auto;
    }
</style>

<div class="login-bg w-100">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-sm-8 col-md-6 col-lg-4">

                <div class="text-center mb-4">
                    <h2 class="fw-bold" style="color: #0d6efd;">
                        <i class="bi bi-hospital text-success me-2"></i>MediTrack
                    </h2>
                </div>

                <div class="card login-card p-4">
                    <div class="card-body">

                        <div class="text-center mb-4">
                            <div class="avatar-circle">
                                <i class="bi bi-person-fill" style="font-size: 3rem; color: #4285F4;"></i>
                            </div>
                            <h4 class="fw-bold text-dark">Acceso Médico</h4>
                            <p class="text-muted small">Ingrese sus credenciales para continuar</p>
                        </div>

                        <form>
                            <div class="mb-3">
                                <label class="form-label fw-bold text-dark small">Usuario o CMP</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0">
                                        <i class="bi bi-person text-muted"></i>
                                    </span>
                                    <input type="text" class="form-control border-start-0 ps-0" placeholder="Ej: DrSanchez" required>
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold text-dark small">Contraseña</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0">
                                        <i class="bi bi-lock text-muted"></i>
                                    </span>
                                    <input type="password" class="form-control border-start-0 ps-0" placeholder="••••••••" required>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between align-items-center mb-4 small">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="rememberMe">
                                    <label class="form-check-label text-muted" for="rememberMe">
                                        Recordarme
                                    </label>
                                </div>
                                <a href="#" class="text-decoration-none" style="color: #4285F4;">¿Olvidó su clave?</a>
                            </div>

                            <div class="d-grid mb-3">
                                <a href="UsarioMedico" class="btn text-white fw-bold py-2.5 rounded-3 shadow-sm" style="background-color: #4285F4; font-size: 1.05rem;">
                                    Ingresar al Sistema
                                </a>
                            </div>

                            <div class="text-center mt-4">
                                <a href="/" class="text-decoration-none text-muted small fw-medium hover-primary">
                                    <i class="bi bi-arrow-left me-1"></i> Volver a la selección de roles
                                </a>
                            </div>
                        </form>

                    </div>
                </div>

            </div>
        </div>
    </div>
</div>



@code {

}
