@page "/Pacientes"

<h3>Listado de Pacientes</h3>

<style>
    .filter-box {
        max-width: 400px;
        margin-bottom: 1.5rem;
        display: flex;
        gap: 10px;
    }

    table th {
        background-color: #f8f9fa;
    }

    .badge-activo {
        background-color: #198754; /* verde */
        color: white;
        padding: 5px 10px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 500;
        display: inline-block;
        text-align: center;
    }

    .badge-inactivo {
        background-color: #dc3545; /* rojo */
        color: white;
        padding: 5px 10px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 500;
        display: inline-block;
        text-align: center;
    }

    .btn-historial {
        background-color: #0d6efd;
        color: white;
        border: none;
        padding: 5px 10px;
        border-radius: 4px;
        text-decoration: none;
        font-size: 0.9rem;
        display: inline-block;
        text-align: center;
    }

        .btn-historial:hover {
            background-color: #0b5ed7;
            color: white;
            text-decoration: none;
        }

    .btn-buscar {
        background-color: #0d6efd;
        color: white;
        border: none;
        padding: 6px 12px;
        border-radius: 4px;
        cursor: pointer;
    }

        .btn-buscar:hover {
            background-color: #0b5ed7;
        }
</style>

<div class="container-fluid">
    <!-- Filtro visual (solo interfaz) -->
    <div class="filter-box">
        <input type="text" class="form-control" placeholder="Filtrar por apellido o DNI...">
        <button class="btn-buscar" type="button">Buscar</button>
    </div>

    <!-- Tabla de pacientes -->
    <div class="table-responsive">
        <table class="table table-hover table-bordered">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nombres</th>
                    <th>Apellidos</th>
                    <th>DNI</th>
                    <th>Edad</th>
                    <th>Teléfono</th>
                    <th>Estado</th>
                    <th>Historial Médico</th>
                </tr>
            </thead>
            <tbody>
                <!-- Paciente 1 (Activo) -->
                <tr>
                    <td>1</td>
                    <td>Ana</td>
                    <td>Ramirez</td>
                    <td>98765432</td>
                    <td>34</td>
                    <td>987654321</td>
                    <td><span class="badge-activo">Activo</span></td>
                    <td><a href="/DetalleHistorial" class="btn-historial">Ver Historial</a></td>
                </tr>
                <!-- Paciente 2 (Activo) -->
                <tr>
                    <td>2</td>
                    <td>Luis</td>
                    <td>Gonzales</td>
                    <td>12345678</td>
                    <td>45</td>
                    <td>912345678</td>
                    <td><span class="badge-activo">Activo</span></td>
                    <td><a href="/ResumenDetalleHistorial" class="btn-historial">Ver Historial</a></td>
                </tr>
                <!-- Paciente 3 (Desactivado) -->
                <tr>
                    <td>3</td>
                    <td>Maria</td>
                    <td>Lopez</td>
                    <td>45678901</td>
                    <td>28</td>
                    <td>954321678</td>
                    <td><span class="badge-inactivo">Desactivado</span></td>
                    <td><a href="/ResumenDetalleHistorial" class="btn-historial">Ver Historial</a></td>
                </tr>
                <!-- Paciente 4 (Activo) -->
                <tr>
                    <td>4</td>
                    <td>Carlos</td>
                    <td>Mendoza</td>
                    <td>78901234</td>
                    <td>52</td>
                    <td>967890123</td>
                    <td><span class="badge-activo">Activo</span></td>
                    <td><a href="/ResumenDetalleHistorial" class="btn-historial">Ver Historial</a></td>
                </tr>
                <!-- Paciente 5 (Desactivado) -->
                <tr>
                    <td>5</td>
                    <td>Carmen</td>
                    <td>Rojas</td>
                    <td>23456789</td>
                    <td>37</td>
                    <td>978654321</td>
                    <td><span class="badge-inactivo">Desactivado</span></td>
                    <td><a href="/ResumenDetalleHistorial" class="btn-historial">Ver Historial</a></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
